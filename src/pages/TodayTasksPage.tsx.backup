  soaking: {
    key: 'soaking',
    title: 'Namáčanie',
    icon: Droplets,
    bgColor: '#dbeafe',
    iconColor: '#2563eb',
    emptyText: 'Dnes nie je potrebné namáčať',
  },
  sowing: {
    key: 'sowing',
    title: 'Výsev',
    icon: Sprout,
    bgColor: '#dcfce7',
    iconColor: '#16a34a',
    emptyText: 'Dnes nie je naplánovaný žiadny výsev',
  },
  weight: {
    key: 'weight',
    title: 'Odťaženie',
    icon: Weight,
    bgColor: '#ede9fe',
    iconColor: '#7c3aed',
    emptyText: 'Dnes nie je potrebné odťažiť',
