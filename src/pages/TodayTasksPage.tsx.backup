  },
};

const formatOrderNumber = (n: number): string => `MR-${String(n).padStart(3, '0')}`;

const overdueLabel = (taskDate: Date, today: Date): string => {
  const diff = differenceInDays(today, taskDate);
  if (diff === 1) return 'Včera';
  if (diff === 2) return 'Predvčerom';
  if (diff < 7) return `Pred ${diff} dňami`;
  if (diff < 14) return 'Pred týždňom';
  return `Pred ${Math.floor(diff / 7)} týždňami`;
};

const getCropsForPlan = (plan: PlantingPlan, crops: Crop[]): Crop[] => {
  // Pre mixed plány vráti všetky plodiny z mix_configuration.
  // Pre obyčajný plán vráti pole s jednou plodinou.
  if (plan.is_mixed && plan.mix_configuration) {
    let mc: any = plan.mix_configuration;
    if (typeof mc === 'string') {
      try { mc = JSON.parse(mc); } catch { mc = []; }
    }
    if (!Array.isArray(mc)) return [];
    const result: Crop[] = [];
    for (const item of mc) {
      const c = crops.find(cr => cr.id === item.crop_id);
      if (c) result.push(c);
    }
    return result;
  }
  if (plan.crop_id) {
    const c = crops.find(cr => cr.id === plan.crop_id);
    return c ? [c] : [];
  }
  return [];
};

const getDisplayCrop = (plan: PlantingPlan, crops: Crop[]): { name: string; color: string; cropId: string | null } => {
  if (plan.is_mixed && plan.mix_configuration) {
    let mc: any = plan.mix_configuration;
    if (typeof mc === 'string') {
      try { mc = JSON.parse(mc); } catch { mc = []; }
    }
    if (Array.isArray(mc) && mc.length > 0) {
      const names = mc.map((item: any) => item.crop_name || crops.find(c => c.id === item.crop_id)?.name).filter(Boolean);
      return {
        name: names.length > 0 ? `Mix: ${names.join(' + ')}` : 'Kombinovaný',
        color: '#7c3aed',
        cropId: null,
      };
    }
    return { name: 'Kombinovaný', color: '#7c3aed', cropId: null };
  }
  if (plan.crops) {
    return { name: plan.crops.name, color: plan.crops.color || '#16a34a', cropId: plan.crop_id };
  }
  const c = crops.find(cr => cr.id === plan.crop_id);
  return {
    name: c?.name || 'Neznáma',
    color: c?.color || '#16a34a',
    cropId: plan.crop_id,
  };
};

// ===================== MAIN COMPONENT =====================

const TodayTasksPage = () => {
  const { isAdmin } = useAuth();
  const { toast } = useToast();
  const isMobile = useIsMobile();
  const navigate = useNavigate();

  // Data state
  const [plans, setPlans] = useState<PlantingPlan[]>([]);
  const [crops, setCrops] = useState<Crop[]>([]);
  const [orders, setOrders] = useState<Order[]>([]);
  const [loading, setLoading] = useState(true);

  // UI state
  // Mobile collapsible state - default zatvorené, overdue vždy otvorené
  const [expandedSections, setExpandedSections] = useState<Record<string, boolean>>({});

  // Locally tracked "soaked" plan IDs (nepersistujeme do DB zatiaľ)
  const [soakedIds, setSoakedIds] = useState<Set<string>>(new Set());

  // Yield dialog state
  const [yieldDialog, setYieldDialog] = useState<{
    open: boolean;
    plan: PlantingPlan | null;
    plannedYield: number;
  }>({ open: false, plan: null, plannedYield: 0 });
  const [actualYield, setActualYield] = useState<number>(0);

  // Saving state per action (aby sa nedalo dvakrát kliknúť)
  const [savingIds, setSavingIds] = useState<Set<string>>(new Set());

  // Today reference
  const today = useMemo(() => startOfDay(new Date()), []);
  const todayStr = useMemo(() => format(today, 'yyyy-MM-dd'), [today]);


  // ===================== FETCH =====================

  const fetchCrops = useCallback(async () => {
    try {
      const { data, error } = await supabase
        .from('products')
        .select('id, name, color, category, days_to_harvest, days_in_darkness, days_on_light, blackout_days, needs_weight, seed_soaking, soaking_duration_hours, tray_configs');
      if (error) throw error;
      setCrops((data as Crop[]) || []);
    } catch (err) {
      console.error('Error fetching crops:', err);
    }
  }, []);

  const fetchPlans = useCallback(async () => {
    try {
      const thirtyDaysAgo = format(addDays(today, -30), 'yyyy-MM-dd');
      // Plánovaný výsev mohol byť až 30 dní pred dnes (meškajúce úlohy).
      // Plán mohol byť aj v budúcnosti (namáčanie sa môže robiť deň pred výsevom).
      // Status filter: planned + in_progress; cancelled/completed nezobrazujeme.
      const tomorrowStr = format(addDays(today, 1), 'yyyy-MM-dd');
      const { data, error } = await supabase
        .from('planting_plans')
        .select(`
          id, crop_id, sow_date, expected_harvest_date, tray_size, tray_count,
          seed_amount_grams, total_seed_grams, status, notes, is_manual, is_mixed,
          is_test, mix_configuration, source_orders, completed_at, actual_yield_grams,
          weight_removed_at, blackout_started_at, blackout_ended_at, moved_to_light_at,
          crops:crop_id ( id, name, color, category, days_to_harvest, days_in_darkness, days_on_light, blackout_days, needs_weight, seed_soaking, soaking_duration_hours, tray_configs )
        `)
        .in('status', ['planned', 'in_progress'])
        .gte('sow_date', thirtyDaysAgo)
        .lte('sow_date', tomorrowStr); // sow_date max zajtra (namáčanie pre zajtrajší výsev)
      if (error) throw error;
      setPlans((data as any[]) || []);
    } catch (err) {
      console.error('Error fetching plans:', err);
      toast({
        title: 'Chyba',
        description: 'Nepodarilo sa načítať plány.',
        variant: 'destructive',
      });
    }
  }, [today, toast]);

  const fetchOrders = useCallback(async () => {
    try {
      // Dnešné objednávky + tie z minulosti ktoré nie sú delivered/cancelled (meškajúce dodávky)
      const thirtyDaysAgo = format(addDays(today, -30), 'yyyy-MM-dd');
      const { data, error } = await supabase
        .from('orders')
        .select(`
          id, order_number, customer_name, delivery_date, delivery_form, status, skipped,
          order_items ( crop_id, quantity, packaging_size, crops:crop_id ( id, name, color ) )
        `)
        .gte('delivery_date', thirtyDaysAgo)
        .lte('delivery_date', todayStr);
      if (error) throw error;
      setOrders((data as any[]) || []);
    } catch (err) {
      console.error('Error fetching orders:', err);
    }
  }, [today, todayStr, toast]);

  const refreshAll = useCallback(async () => {
    setLoading(true);
    await Promise.all([fetchCrops(), fetchPlans(), fetchOrders()]);
    setLoading(false);
  }, [fetchCrops, fetchPlans, fetchOrders]);

  useEffect(() => {
    refreshAll();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  // ===================== DERIVED HELPERS =====================

  // Vráti dátum ako 'yyyy-MM-dd' string z timestamptz (čítaj len date časť)
  const dateOnlyFromTimestamp = (ts: string | null | undefined): string | null => {
    if (!ts) return null;
    try { return ts.split('T')[0]; } catch { return null; }
  };

  // Konvertuje plán na BaseTaskItem (pre kategórie 1-6)
  const planToTaskItem = useCallback((plan: PlantingPlan, category: TaskCategoryKey, isOverdue: boolean, overdueDateRef?: Date): BaseTaskItem => {
    const display = getDisplayCrop(plan, crops);
    return {
      id: `${category}-${plan.id}`,
      category,
      cropId: display.cropId,
      cropName: display.name,
      cropColor: display.color,
      trayInfo: `${plan.tray_count}×${plan.tray_size}`,
      seedGrams: Math.round((plan.total_seed_grams || 0) * 10) / 10,
      isMixed: !!plan.is_mixed,
      isTest: !!plan.is_test,
      isManual: !!plan.is_manual,
      isOverdue,
      overdueLabel: isOverdue && overdueDateRef ? overdueLabel(overdueDateRef, today) : undefined,
      planId: plan.id,
    };
  }, [crops, today]);

  // ===================== TASK CATEGORIES =====================

  // 1. NAMÁČANIE — plány kde crop.seed_soaking=true AND status='planned'
  // AND sow_date - soaking_hours sa rovná dnes
  const soakingTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status !== 'planned') continue;
      const planCrops = getCropsForPlan(plan, crops);
      // Aspoň jedna plodina musí mať seed_soaking
      const soakingCrop = planCrops.find(c => c.seed_soaking);
      if (!soakingCrop) continue;
      const hours = Number(soakingCrop.soaking_duration_hours) || 12;
      const sowDate = parseISO(plan.sow_date);
      const soakDate = subHours(sowDate, hours);
      const soakDateStart = startOfDay(soakDate);
      // Dnes vrátane minulosti (zachytí aj meškajúce — ak deň pred výsevom prebehol)
      if (isSameDay(soakDateStart, today)) {
        result.push(planToTaskItem(plan, 'soaking', false));
      } else if (soakDateStart < today && plan.sow_date >= todayStr) {
        // Meškajúce namáčanie — bolo treba namočiť včera ale výsev je dnes/zajtra
        result.push(planToTaskItem(plan, 'soaking', true, soakDateStart));
      }
    }
    return result;
  }, [plans, crops, today, todayStr, planToTaskItem]);

  // 2. VÝSEV — plány kde status='planned' AND sow_date = today
  const sowingTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status !== 'planned') continue;
      if (plan.sow_date === todayStr) {
        result.push(planToTaskItem(plan, 'sowing', false));
      } else if (plan.sow_date < todayStr) {
        // Meškajúci výsev
        result.push(planToTaskItem(plan, 'sowing', true, parseISO(plan.sow_date)));
      }
    }
    return result;
  }, [plans, todayStr, planToTaskItem]);

  // 3. ODŤAŽENIE — plány kde crop.needs_weight=true AND status='in_progress'
  // AND sow_date + days_in_darkness = today AND weight_removed_at IS NULL
  // Pre mixed: aspoň jedna plodina v mixe potrebuje záťaž
  const weightTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status !== 'in_progress') continue;
      if (plan.weight_removed_at) continue;
      const planCrops = getCropsForPlan(plan, crops);
      const weightCrop = planCrops.find(c => c.needs_weight);
      if (!weightCrop) continue;
      // days_in_darkness pre mix berieme max (najdlhšie čaká)
      const maxDarkness = Math.max(...planCrops.map(c => c.days_in_darkness || 2));
      const targetDate = addDays(parseISO(plan.sow_date), maxDarkness);
      if (isSameDay(targetDate, today)) {
        result.push(planToTaskItem(plan, 'weight', false));
      } else if (targetDate < today) {
        result.push(planToTaskItem(plan, 'weight', true, targetDate));
      }
    }
    return result;
  }, [plans, crops, today, planToTaskItem]);

  // 4. ZAKRYTIE PRE BO — plány kde crop.blackout_days > 0
  // AND weight_removed_at IS NOT NULL AND weight_removed_at::date = today
  // AND blackout_started_at IS NULL
  // POZN: pre plány bez záťaže ale s BO — kryjú sa hneď po days_in_darkness
  const coverBoTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status !== 'in_progress') continue;
      if (plan.blackout_started_at) continue;
      const planCrops = getCropsForPlan(plan, crops);
      // Aspoň jedna plodina v mixe má blackout_days > 0
      const boCrop = planCrops.find(c => (c.blackout_days || 0) > 0);
      if (!boCrop) continue;

      // Variant A: má záťaž, čakáme až bola odstránená dnes
      if (plan.weight_removed_at) {
        const removedDate = dateOnlyFromTimestamp(plan.weight_removed_at);
        if (removedDate === todayStr) {
          result.push(planToTaskItem(plan, 'cover_bo', false));
        } else if (removedDate && removedDate < todayStr) {
          result.push(planToTaskItem(plan, 'cover_bo', true, parseISO(removedDate)));
        }
      } else {
        // Variant B: nemá záťaž (needs_weight=false na všetkých plodinách)
        const anyNeedsWeight = planCrops.some(c => c.needs_weight);
        if (anyNeedsWeight) continue; // čakáme na odťaženie
        // Bez záťaže → BO sa začne po days_in_darkness
        const maxDarkness = Math.max(...planCrops.map(c => c.days_in_darkness || 2));
        const targetDate = addDays(parseISO(plan.sow_date), maxDarkness);
        if (isSameDay(targetDate, today)) {
          result.push(planToTaskItem(plan, 'cover_bo', false));
        } else if (targetDate < today) {
          result.push(planToTaskItem(plan, 'cover_bo', true, targetDate));
        }
      }
    }
    return result;
  }, [plans, crops, today, todayStr, planToTaskItem]);

  // 5. PRESUN NA SVETLO (kombinuje 5a a 5b a "nová" 3. cestu pre plodiny bez záťaže aj bez BO)
  const lightTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status !== 'in_progress') continue;
      if (plan.moved_to_light_at) continue;

      const planCrops = getCropsForPlan(plan, crops);
      if (planCrops.length === 0) continue;
      const maxBlackout = Math.max(...planCrops.map(c => c.blackout_days || 0));
      const maxDarkness = Math.max(...planCrops.map(c => c.days_in_darkness || 2));
      const anyNeedsWeight = planCrops.some(c => c.needs_weight);

      let targetDate: Date | null = null;

      if (maxBlackout > 0 && plan.blackout_started_at && !plan.blackout_ended_at) {
        // 5a: ukončenie BO + presun na svetlo
        const boStartDate = parseISO(dateOnlyFromTimestamp(plan.blackout_started_at)!);
        targetDate = addDays(boStartDate, maxBlackout);
      } else if (maxBlackout === 0 && anyNeedsWeight && plan.weight_removed_at && !plan.moved_to_light_at) {
        // 5b: bez BO ale so záťažou — presun na svetlo ten istý deň ako odťaženie
        const removedDateStr = dateOnlyFromTimestamp(plan.weight_removed_at);
        if (removedDateStr) targetDate = parseISO(removedDateStr);
      } else if (maxBlackout === 0 && !anyNeedsWeight) {
        // 5c: bez záťaže AJ bez BO — po days_in_darkness rovno na svetlo
        targetDate = addDays(parseISO(plan.sow_date), maxDarkness);
      }

      if (!targetDate) continue;
      if (isSameDay(targetDate, today)) {
        result.push(planToTaskItem(plan, 'light', false));
      } else if (targetDate < today) {
        result.push(planToTaskItem(plan, 'light', true, targetDate));
      }
    }
    return result;
  }, [plans, crops, today, planToTaskItem]);

  // 6. ZBER — plány kde expected_harvest_date = today AND status != 'completed'
  const harvestTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const plan of plans) {
      if (plan.status === 'completed') continue;
      if (!plan.expected_harvest_date) continue;
      if (plan.expected_harvest_date === todayStr) {
        result.push(planToTaskItem(plan, 'harvest', false));
      } else if (plan.expected_harvest_date < todayStr) {
        result.push(planToTaskItem(plan, 'harvest', true, parseISO(plan.expected_harvest_date)));
      }
    }
    return result;
  }, [plans, todayStr, planToTaskItem]);

  // 7. BALENIE A EXPEDÍCIA — orders kde delivery_date = today AND status NOT IN ('delivered','cancelled')
  // AND skipped != true. Read-only.
  const deliveryTasks = useMemo<BaseTaskItem[]>(() => {
    const result: BaseTaskItem[] = [];
    for (const order of orders) {
      if (order.skipped === true) continue;
      if (order.status === 'delivered' || order.status === 'cancelled' || order.status === 'dorucena' || order.status === 'zrusena') continue;
      const isToday = order.delivery_date === todayStr;
      const isOverdue = order.delivery_date < todayStr;
      if (!isToday && !isOverdue) continue;

      const items = order.order_items || [];
      // Pre každú položku objednávky vytvoríme jeden riadok
      if (items.length === 0) {
        result.push({
          id: `delivery-${order.id}`,
          category: 'delivery',
          cropId: null,
          cropName: 'Bez položiek',
          cropColor: '#94a3b8',
          trayInfo: '',
          seedGrams: 0,
          isMixed: false,
          isTest: false,
          isManual: false,
          isOverdue,
          overdueLabel: isOverdue ? overdueLabel(parseISO(order.delivery_date), today) : undefined,
          orderId: order.id,
          orderNumber: order.order_number,
          customerName: order.customer_name || 'Neznámy',
          deliveryForm: order.delivery_form || undefined,
        });
        continue;
      }
      // Zobrazíme jeden riadok per objednávka, plodiny zlúčime do názvu
      const itemNames = items.map(it => it.crops?.name).filter(Boolean);
      const itemGrams = items.reduce((sum, it) => {
        const g = parseFloat((it.packaging_size || '').replace(/[^0-9.]/g, '') || '0') * (it.quantity || 0);
        return sum + g;
      }, 0);
      result.push({
        id: `delivery-${order.id}`,
        category: 'delivery',
        cropId: items[0]?.crop_id || null,
        cropName: itemNames.length > 1 ? `${itemNames.length} položiek` : (itemNames[0] || 'Položka'),
        cropColor: items[0]?.crops?.color || '#0ea5e9',
        trayInfo: `${Math.round(itemGrams)}g`,
        seedGrams: 0,
        isMixed: itemNames.length > 1,
        isTest: false,
        isManual: false,
        isOverdue,
        overdueLabel: isOverdue ? overdueLabel(parseISO(order.delivery_date), today) : undefined,
        orderId: order.id,
        orderNumber: order.order_number,
        customerName: order.customer_name || 'Neznámy',
        deliveryForm: order.delivery_form || undefined,
      });
    }
    return result;
  }, [orders, today, todayStr]);

  // Všetky úlohy z kategórií 1-6 v jednom poli (pre overdue banner + counts)
  const allTaskItems = useMemo<BaseTaskItem[]>(() => {
    return [...soakingTasks, ...sowingTasks, ...weightTasks, ...coverBoTasks, ...lightTasks, ...harvestTasks, ...deliveryTasks];
  }, [soakingTasks, sowingTasks, weightTasks, coverBoTasks, lightTasks, harvestTasks, deliveryTasks]);

  // Meškajúce úlohy (samostatne pre banner hore)
  const overdueTasks = useMemo<BaseTaskItem[]>(() => {
    return allTaskItems.filter(t => t.isOverdue);
  }, [allTaskItems]);

  // Dnešné úlohy (nie overdue)
  const todayOnlyTasks = useMemo<BaseTaskItem[]>(() => {
    return allTaskItems.filter(t => !t.isOverdue);
  }, [allTaskItems]);

  // Pre každú kategóriu len dnešné (nie overdue, lebo overdue sú v bannerii hore)
  const tasksByCategory = useMemo<Record<TaskCategoryKey, BaseTaskItem[]>>(() => ({
    soaking: soakingTasks.filter(t => !t.isOverdue),
    sowing: sowingTasks.filter(t => !t.isOverdue),
    weight: weightTasks.filter(t => !t.isOverdue),
    cover_bo: coverBoTasks.filter(t => !t.isOverdue),
    light: lightTasks.filter(t => !t.isOverdue),
    harvest: harvestTasks.filter(t => !t.isOverdue),
    delivery: deliveryTasks.filter(t => !t.isOverdue),
  }), [soakingTasks, sowingTasks, weightTasks, coverBoTasks, lightTasks, harvestTasks, deliveryTasks]);

  // Counts pre header
  const totalTaskCount = todayOnlyTasks.length;
  const completedTaskCount = useMemo(() => {
    // Lokálne "hotové" — pre soaking je v soakedIds, pre ostatné sa berie z DB (po refresh prejdú do iných kategórií)
    // Súčasná logika: úlohy už zmiznú zo zoznamu keď sú hotové (lebo filter na DB stav).
    // Súčet hotových je preto fakticky 0 viditeľných, ale: chceme to zobraziť ako "X z Y" hotových za deň.
    // Riešenie: počítame koľko by ich malo byť celkom (overdue + dnes) a hotových = (overdue/today complete dnes — nemáme persistovaný stav).
    // Najjednoduchšia interpretácia: zo všetkých "dnes ráno" úloh, koľko je hotových.
    // Použijeme: pre soaking počítame z lokálneho stavu, pre ostatné porovnáme s DB tým, že úlohy zmizli.
    // Pre teraz: nezobrazujeme x/y, ale len celkový počet zostávajúcich + soaked.
    return soakedIds.size; // placeholder
  }, [soakedIds]);


  // ===================== ACTION HANDLERS =====================

  const markSavingStart = (id: string) => {
    setSavingIds(prev => {
      const next = new Set(prev);
      next.add(id);
      return next;
    });
  };
  const markSavingEnd = (id: string) => {
    setSavingIds(prev => {
      const next = new Set(prev);
      next.delete(id);
      return next;
    });
  };

  // 1. Namáčanie — lokálne (NIE DB)
  const handleMarkSoaked = (planId: string) => {
    setSoakedIds(prev => {
      const next = new Set(prev);
      next.add(planId);
      return next;
    });
    toast({ title: 'Namočené', description: 'Označené ako hotové.' });
  };

  // 2. Výsev — status='planned' → 'in_progress'
  const handleMarkSown = async (planId: string) => {
    if (savingIds.has(planId)) return;
    markSavingStart(planId);
    try {
      const { error } = await supabase
        .from('planting_plans')
        .update({ status: 'in_progress' })
        .eq('id', planId);
      if (error) throw error;
      toast({ title: 'Posadené', description: 'Výsev označený ako prebieha.' });
      await fetchPlans();
    } catch (err: any) {
      console.error('handleMarkSown error:', err);
      toast({ title: 'Chyba', description: err.message || 'Nepodarilo sa uložiť.', variant: 'destructive' });
    } finally {
      markSavingEnd(planId);
    }
  };

  // 3. Odťaženie — weight_removed_at = now
  const handleMarkWeightRemoved = async (planId: string) => {
    if (savingIds.has(planId)) return;
    markSavingStart(planId);
    try {
      const { error } = await supabase
        .from('planting_plans')
        .update({ weight_removed_at: new Date().toISOString() })
        .eq('id', planId);
      if (error) throw error;
      toast({ title: 'Odťažené', description: 'Záťaž bola odstránená.' });
      await fetchPlans();
    } catch (err: any) {
      console.error('handleMarkWeightRemoved error:', err);
      toast({ title: 'Chyba', description: err.message || 'Nepodarilo sa uložiť.', variant: 'destructive' });
    } finally {
      markSavingEnd(planId);
    }
  };

  // 4. Zakrytie BO — blackout_started_at = now
  const handleMarkBlackoutStarted = async (planId: string) => {
    if (savingIds.has(planId)) return;
    markSavingStart(planId);
    try {
      const { error } = await supabase
        .from('planting_plans')
        .update({ blackout_started_at: new Date().toISOString() })
        .eq('id', planId);
      if (error) throw error;
      toast({ title: 'Zakryté', description: 'Tácka je v blackout fáze.' });
      await fetchPlans();
    } catch (err: any) {
      console.error('handleMarkBlackoutStarted error:', err);
      toast({ title: 'Chyba', description: err.message || 'Nepodarilo sa uložiť.', variant: 'destructive' });
    } finally {
      markSavingEnd(planId);
    }
  };

  // 5. Presun na svetlo — moved_to_light_at + (ak BO) blackout_ended_at
  const handleMarkMovedToLight = async (planId: string) => {
    if (savingIds.has(planId)) return;
    markSavingStart(planId);
    try {
      const plan = plans.find(p => p.id === planId);
      if (!plan) throw new Error('Plán nenájdený');
      const now = new Date().toISOString();
      const updates: any = { moved_to_light_at: now };
      // Ak je v BO a ešte nemá ended → uzavri BO
      if (plan.blackout_started_at && !plan.blackout_ended_at) {
        updates.blackout_ended_at = now;
      }
      const { error } = await supabase
        .from('planting_plans')
        .update(updates)
        .eq('id', planId);
      if (error) throw error;
      toast({ title: 'Na svetle', description: 'Tácka je presunutá pod svetlo.' });
      await fetchPlans();
    } catch (err: any) {
      console.error('handleMarkMovedToLight error:', err);
      toast({ title: 'Chyba', description: err.message || 'Nepodarilo sa uložiť.', variant: 'destructive' });
    } finally {
      markSavingEnd(planId);
    }
  };

  // 6. Zber — otvor yield dialog
  const handleOpenHarvestDialog = (planId: string) => {
    const plan = plans.find(p => p.id === planId);
    if (!plan) return;
    // Vypočítaj plánovaný výnos pre dialog
    const planCrops = getCropsForPlan(plan, crops);
    let plannedYield = 0;
    if (planCrops.length > 0 && planCrops[0].tray_configs) {
      const cfg = planCrops[0].tray_configs[plan.tray_size];
      if (cfg) {
        plannedYield = (cfg.yield_grams || cfg.expected_yield || 0) * plan.tray_count;
      }
    }
    setYieldDialog({ open: true, plan, plannedYield });
    setActualYield(0);
  };

  const handleConfirmHarvest = async () => {
    if (!yieldDialog.plan) return;
    const plan = yieldDialog.plan;
    if (savingIds.has(plan.id)) return;
    markSavingStart(plan.id);
    try {
      const updates: any = {
        status: 'completed',
        completed_at: new Date().toISOString(),
      };
      if (actualYield > 0) {
        updates.actual_yield_grams = actualYield;
      }
      const { error } = await supabase
        .from('planting_plans')
        .update(updates)
        .eq('id', plan.id);
      if (error) throw error;
      toast({ title: 'Zozbierané', description: 'Výsev dokončený.' });
      setYieldDialog({ open: false, plan: null, plannedYield: 0 });
      setActualYield(0);
      await fetchPlans();
    } catch (err: any) {
      console.error('handleConfirmHarvest error:', err);
      toast({ title: 'Chyba', description: err.message || 'Nepodarilo sa uložiť.', variant: 'destructive' });
    } finally {
      markSavingEnd(plan.id);
    }
  };

  // Generic action dispatcher — vyberie správnu akciu podľa kategórie
  const handleTaskAction = (item: BaseTaskItem) => {
    if (!item.planId) return;
    switch (item.category) {
      case 'soaking':
        handleMarkSoaked(item.planId);
        break;
      case 'sowing':
        handleMarkSown(item.planId);
        break;
      case 'weight':
        handleMarkWeightRemoved(item.planId);
        break;
      case 'cover_bo':
        handleMarkBlackoutStarted(item.planId);
        break;
      case 'light':
        handleMarkMovedToLight(item.planId);
        break;
      case 'harvest':
        handleOpenHarvestDialog(item.planId);
        break;
      // delivery — žiadna akcia
    }
  };

  const handleOpenPlan = (planId: string) => {
    navigate(`/planting-plan?planId=${planId}`);
  };

  // ===================== UI HELPERS =====================

  const toggleSection = (key: string) => {
    setExpandedSections(prev => ({ ...prev, [key]: !prev[key] }));
  };

  const isSectionExpanded = (key: string, defaultOpen: boolean): boolean => {
    if (expandedSections[key] !== undefined) return expandedSections[key];
    return defaultOpen;
  };

  const getActionLabel = (category: TaskCategoryKey): string => {
    switch (category) {
      case 'soaking': return 'Namočené';
      case 'sowing': return 'Posadené';
      case 'weight': return 'Odťažené';
      case 'cover_bo': return 'Zakryté';
      case 'light': return 'Na svetlo';
      case 'harvest': return 'Zozbierané';
      case 'delivery': return '';
    }
  };

  // Zoznam všetkých kategórií v poradí
  const orderedCategories: TaskCategoryKey[] = ['soaking', 'sowing', 'weight', 'cover_bo', 'light', 'harvest', 'delivery'];

  // Súhrn (progress) - bezpečnejší výpočet
  const progressData = useMemo(() => {
    const remaining = todayOnlyTasks.length;
    const soaked = Array.from(soakedIds).length;
    // "Hotové" za deň ako proxy: soaked + (orderedCategories spočítané refresh-mi nevidíme retroaktívne)
    // Realisticky zobrazujeme len: "Zostáva X úloh"
    return { remaining, soaked };
  }, [todayOnlyTasks, soakedIds]);


  // ===================== RENDER =====================

  return (
    <MainLayout hideMobileHeader>
      <div className="min-h-screen bg-[#f8fafc] pb-20 md:pb-6">
        {/* HEADER */}
        <div className="bg-white border-b border-[#e2e8f0] px-4 md:px-6 py-4">
          <div className="container mx-auto flex items-center justify-between gap-4">
            <div className="flex items-center gap-3 min-w-0">
              <div className="flex-shrink-0 w-10 h-10 rounded-xl bg-[#f0fdf4] border border-[#bbf7d0] flex items-center justify-center">
                <Sprout className="h-5 w-5 text-[#16a34a]" />
              </div>
              <div className="min-w-0">
                <h1 className="text-lg md:text-xl font-bold text-[#0f172a] truncate">Dnešné úlohy</h1>
                <p className="text-xs md:text-sm text-[#475569] capitalize truncate">
                  {format(today, "EEEE, d. MMMM yyyy", { locale: sk })}
                  {totalTaskCount > 0 && (
                    <span className="ml-2">
                      • <span className="font-semibold text-[#0f172a]">{totalTaskCount}</span> {totalTaskCount === 1 ? 'úloha' : (totalTaskCount >= 2 && totalTaskCount <= 4 ? 'úlohy' : 'úloh')}
                    </span>
                  )}
                  {overdueTasks.length > 0 && (
                    <span className="ml-2 text-[#dc2626]">
                      • {overdueTasks.length} {overdueTasks.length === 1 ? 'meškajúca' : (overdueTasks.length >= 2 && overdueTasks.length <= 4 ? 'meškajúce' : 'meškajúcich')}
                    </span>
                  )}
                </p>
              </div>
            </div>
          </div>
        </div>

        <div className="container mx-auto px-4 md:px-6 py-4 md:py-6 space-y-4">

          {/* LOADING SKELETON */}
          {loading ? (
            <div className="grid gap-3 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
              {[...Array(6)].map((_, i) => (
                <div key={i} className="bg-white rounded-xl border border-[#cbd5e1] shadow-sm p-4">
                  <div className="flex items-center gap-3 mb-3">
                    <Skeleton className="h-10 w-10 rounded-xl" />
                    <Skeleton className="h-5 w-32" />
                  </div>
                  <Skeleton className="h-16 w-full" />
                </div>
              ))}
            </div>
          ) : (
            <>
              {/* OVERDUE BANNER */}
              {overdueTasks.length > 0 && (
                <OverdueBanner
                  tasks={overdueTasks}
                  isMobile={isMobile}
                  isAdmin={isAdmin}
                  savingIds={savingIds}
                  soakedIds={soakedIds}
                  onAction={handleTaskAction}
                  onOpenPlan={handleOpenPlan}
                  getActionLabel={getActionLabel}
                />
              )}

              {/* CATEGORY GRID */}
              <div className="grid gap-3 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
                {orderedCategories.map(catKey => (
                  <TaskCard
                    key={catKey}
                    config={CATEGORY_CONFIG[catKey]}
                    tasks={tasksByCategory[catKey]}
                    isMobile={isMobile}
                    isAdmin={isAdmin}
                    savingIds={savingIds}
                    soakedIds={soakedIds}
                    isExpanded={isSectionExpanded(catKey, !isMobile)}
                    onToggle={() => toggleSection(catKey)}
                    onAction={handleTaskAction}
                    onOpenPlan={handleOpenPlan}
                    getActionLabel={getActionLabel}
                  />
                ))}
              </div>

              {/* EMPTY STATE */}
              {totalTaskCount === 0 && overdueTasks.length === 0 && (
                <div className="bg-white rounded-xl border border-[#cbd5e1] shadow-sm p-12 flex flex-col items-center justify-center text-center">
                  <div className="w-14 h-14 rounded-xl bg-[#f0fdf4] border border-[#bbf7d0] flex items-center justify-center mb-3">
                    <CheckCircle2 className="h-7 w-7 text-[#16a34a]" />
                  </div>
                  <h3 className="text-base font-bold text-[#0f172a] mb-1">Žiadne úlohy na dnes</h3>
                  <p className="text-sm text-[#475569] max-w-sm">
                    Pekný deň — nemáš naplánované žiadne výsevy, presuny ani zbery.
                  </p>
                </div>
              )}
            </>
          )}
        </div>

        {/* YIELD DIALOG */}
        <Dialog
          open={yieldDialog.open}
          onOpenChange={(open) => {
            if (!open) {
              setYieldDialog({ open: false, plan: null, plannedYield: 0 });
              setActualYield(0);
            }
          }}
        >
          <DialogContent className="max-w-md bg-white">
            <DialogHeader>
              <DialogTitle className="text-[#0f172a] flex items-center gap-2">
                <Scale className="h-5 w-5 text-[#16a34a]" />
                Zaznamenať výnos
              </DialogTitle>
              <DialogDescription className="text-[#475569]">
                {yieldDialog.plan && getDisplayCrop(yieldDialog.plan, crops).name}
                {yieldDialog.plan && ` — ${yieldDialog.plan.tray_count}×${yieldDialog.plan.tray_size}`}
              </DialogDescription>
            </DialogHeader>

            {yieldDialog.plan && (
              <div className="space-y-4">
                {yieldDialog.plannedYield > 0 && (
                  <div className="bg-[#f8fafc] rounded-lg border border-[#e2e8f0] p-3 flex justify-between text-sm">
                    <span className="text-[#475569]">Plánovaný výnos:</span>
                    <span className="font-bold text-[#0f172a]">{Math.round(yieldDialog.plannedYield)}g</span>
                  </div>
                )}
                <div>
                  <Label htmlFor="yield-input" className="text-xs font-semibold text-[#475569]">
                    Skutočný výnos (g)
                  </Label>
                  <Input
                    id="yield-input"
                    type="number"
                    min="0"
                    step="1"
                    value={actualYield === 0 ? '' : actualYield}
                    onChange={(e) => setActualYield(e.target.value === '' ? 0 : parseInt(e.target.value))}
                    placeholder="napr. 320"
                    className="text-sm h-11 mt-1.5 border-[#e2e8f0]"
                  />
                  <p className="text-[11px] text-[#475569] mt-1">
                    Voliteľné — nechaj prázdne ak nechceš zaznamenať výnos.
                  </p>
                </div>
              </div>
            )}

            <DialogFooter className="gap-2">
              <button
                onClick={() => {
                  setYieldDialog({ open: false, plan: null, plannedYield: 0 });
                  setActualYield(0);
                }}
                className="h-11 px-4 rounded-md border border-[#e2e8f0] bg-white text-[#475569] hover:bg-[#f8fafc] text-sm font-semibold transition-colors"
              >
                Zrušiť
              </button>
              <button
                onClick={handleConfirmHarvest}
                disabled={yieldDialog.plan ? savingIds.has(yieldDialog.plan.id) : false}
                className="h-11 px-4 rounded-md bg-[#16a34a] hover:bg-[#15803d] text-white text-sm font-semibold flex items-center gap-2 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
              >
                {yieldDialog.plan && savingIds.has(yieldDialog.plan.id) ? (
                  <Loader2 className="h-4 w-4 animate-spin" />
                ) : (
                  <CheckCircle2 className="h-4 w-4" />
                )}
                Dokončiť výsev
              </button>
            </DialogFooter>
          </DialogContent>
        </Dialog>
      </div>
    </MainLayout>
  );
};

export default TodayTasksPage;


// ===================== SUB-COMPONENTS =====================

// --- TaskItem (jeden riadok úlohy) ---
interface TaskItemProps {
  task: BaseTaskItem;
  isAdmin: boolean;
  isSaving: boolean;
  isCompleted: boolean; // soaking - lokálne hotové
  isOverdueRow?: boolean; // pre overdue banner - jemne iné štýly
  onAction: (item: BaseTaskItem) => void;
  onOpenPlan: (planId: string) => void;
  getActionLabel: (category: TaskCategoryKey) => string;
}

const TaskItem = ({
  task,
  isAdmin,
  isSaving,
  isCompleted,
  isOverdueRow,
  onAction,
  onOpenPlan,
  getActionLabel,
}: TaskItemProps) => {
  const Icon = CATEGORY_CONFIG[task.category].icon;
  const isDelivery = task.category === 'delivery';

  return (
    <div
      className={cn(
        'px-3 py-3 transition-colors',
        isCompleted && 'opacity-60',
        task.isManual && !isOverdueRow && 'border-l-4 border-l-[#f59e0b] pl-2'
      )}
    >
      <div className="flex items-start gap-3">
        {/* Farebná bodka plodiny */}
        <div
          className="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center border"
          style={{
            backgroundColor: `${task.cropColor}15`,
            borderColor: `${task.cropColor}30`,
          }}
        >
          {task.isMixed ? (
            <Layers className="h-4 w-4" style={{ color: task.cropColor }} />
          ) : isDelivery ? (
            <Package className="h-4 w-4" style={{ color: task.cropColor }} />
          ) : (
            <Icon className="h-4 w-4" style={{ color: task.cropColor }} />
          )}
        </div>

        {/* Info */}
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-1.5 flex-wrap">
            {isDelivery && task.orderNumber && (
              <span className="font-mono text-xs font-bold text-[#0ea5e9]">
                {formatOrderNumber(task.orderNumber)}
              </span>
            )}
            <span
              className={cn(
                'font-bold text-sm text-[#0f172a]',
                isCompleted && 'line-through'
              )}
            >
              {isDelivery ? task.customerName : task.cropName}
            </span>
            {task.isTest && (
              <span className="inline-flex items-center gap-0.5 h-4 px-1.5 rounded bg-[#fef3c7] text-[#92400e] text-[9px] font-bold">
                <FlaskConical className="h-2.5 w-2.5" />
                TEST
              </span>
            )}
            {task.isManual && (
              <span className="inline-flex items-center h-4 px-1.5 rounded bg-[#fef3c7] text-[#92400e] text-[9px] font-bold">
                ✎
              </span>
            )}
            {task.isOverdue && task.overdueLabel && (
              <span className="inline-flex items-center h-4 px-1.5 rounded bg-[#fef2f2] text-[#dc2626] text-[9px] font-bold">
                {task.overdueLabel}
              </span>
            )}
          </div>
          <p className="text-xs text-[#475569] mt-0.5 truncate">
            {isDelivery
              ? `${task.cropName}${task.trayInfo ? ' • ' + task.trayInfo : ''}${task.deliveryForm === 'cut' ? ' • rezané' : task.deliveryForm === 'live' ? ' • živé' : ''}`
              : `${task.trayInfo}${task.seedGrams > 0 ? ` • ${task.seedGrams}g semien` : ''}`}
          </p>
        </div>
      </div>

      {/* Action buttons */}
      <div className="flex items-center gap-2 mt-2 pl-12">
        {!isDelivery && !isCompleted && (
          <button
            onClick={() => onAction(task)}
            disabled={!isAdmin || isSaving}
            className="flex-1 sm:flex-initial h-11 sm:h-9 px-3 rounded-md bg-[#16a34a] hover:bg-[#15803d] disabled:opacity-50 disabled:cursor-not-allowed text-white text-xs font-semibold flex items-center justify-center gap-1.5 transition-colors min-w-0"
          >
            {isSaving ? <Loader2 className="h-3.5 w-3.5 animate-spin" /> : <CheckCircle2 className="h-3.5 w-3.5" />}
            <span className="truncate">{getActionLabel(task.category)}</span>
          </button>
        )}
        {!isDelivery && isCompleted && (
          <span className="flex-1 sm:flex-initial h-11 sm:h-9 px-3 rounded-md bg-[#f0fdf4] border border-[#bbf7d0] text-[#166534] text-xs font-semibold flex items-center justify-center gap-1.5">
            <CheckCircle2 className="h-3.5 w-3.5" />
            Hotové
          </span>
        )}
        {task.planId && (
          <button
            onClick={() => onOpenPlan(task.planId!)}
            className="h-11 sm:h-9 px-3 rounded-md border border-[#e2e8f0] bg-white text-[#475569] hover:border-[#bbf7d0] hover:text-[#16a34a] text-xs font-semibold flex items-center gap-1.5 transition-colors"
          >
            <ExternalLink className="h-3.5 w-3.5" />
            <span className="hidden sm:inline">Otvoriť plán</span>
          </button>
        )}
      </div>
    </div>
  );
};

// --- TaskCard (jedna kategória úloh) ---
interface TaskCardProps {
  config: CategoryConfig;
  tasks: BaseTaskItem[];
  isMobile: boolean;
  isAdmin: boolean;
  savingIds: Set<string>;
  soakedIds: Set<string>;
  isExpanded: boolean;
  onToggle: () => void;
  onAction: (item: BaseTaskItem) => void;
  onOpenPlan: (planId: string) => void;
  getActionLabel: (category: TaskCategoryKey) => string;
}

const TaskCard = ({
  config,
  tasks,
  isMobile,
  isAdmin,
  savingIds,
  soakedIds,
  isExpanded,
  onToggle,
  onAction,
  onOpenPlan,
  getActionLabel,
}: TaskCardProps) => {
  const Icon = config.icon;
  const hasContent = tasks.length > 0;
  const showExpanded = !isMobile || isExpanded; // Desktop/tablet vždy rozbalené

  return (
    <div className="bg-white rounded-xl border border-[#cbd5e1] shadow-sm overflow-hidden flex flex-col">
      {/* Header */}
      <button
        onClick={isMobile ? onToggle : undefined}
        disabled={!isMobile}
        className={cn(
          'flex items-center gap-3 px-4 py-3 border-b-2 border-[#e2e8f0]',
          isMobile && hasContent && 'cursor-pointer hover:bg-[#f8fafc] transition-colors',
          !isMobile && 'cursor-default'
        )}
        style={{ backgroundColor: '#f8fafc' }}
      >
        <div
          className="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center"
          style={{ backgroundColor: config.bgColor }}
        >
          <Icon className="h-4 w-4" style={{ color: config.iconColor }} />
        </div>
        <div className="flex-1 min-w-0 text-left">
          <h3 className="text-sm font-bold text-[#0f172a] truncate">{config.title}</h3>
          {hasContent && (
            <p className="text-[11px] text-[#475569]">
              {tasks.length} {tasks.length === 1 ? 'úloha' : (tasks.length >= 2 && tasks.length <= 4 ? 'úlohy' : 'úloh')}
            </p>
          )}
        </div>
        {hasContent && (
          <span
            className="inline-flex items-center justify-center min-w-[24px] h-6 px-2 rounded-full text-[11px] font-bold"
            style={{ backgroundColor: config.bgColor, color: config.iconColor }}
          >
            {tasks.length}
          </span>
        )}
        {isMobile && hasContent && (
          isExpanded
            ? <ChevronUp className="h-4 w-4 text-[#475569] flex-shrink-0" />
            : <ChevronDown className="h-4 w-4 text-[#475569] flex-shrink-0" />
        )}
      </button>

      {/* Body */}
      {showExpanded && (
        <div className="flex-1">
          {!hasContent ? (
            <p className="text-xs text-[#94a3b8] italic px-4 py-4">{config.emptyText}</p>
          ) : (
            <div className="divide-y divide-[#e2e8f0]">
              {tasks.map(task => (
                <TaskItem
                  key={task.id}
                  task={task}
                  isAdmin={isAdmin}
                  isSaving={task.planId ? savingIds.has(task.planId) : false}
                  isCompleted={task.category === 'soaking' && !!task.planId && soakedIds.has(task.planId)}
                  onAction={onAction}
                  onOpenPlan={onOpenPlan}
                  getActionLabel={getActionLabel}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  );
};

// --- OverdueBanner (sekcia hore so všetkými meškajúcimi) ---
interface OverdueBannerProps {
  tasks: BaseTaskItem[];
  isMobile: boolean;
  isAdmin: boolean;
  savingIds: Set<string>;
  soakedIds: Set<string>;
  onAction: (item: BaseTaskItem) => void;
  onOpenPlan: (planId: string) => void;
  getActionLabel: (category: TaskCategoryKey) => string;
}

const OverdueBanner = ({
  tasks,
  isMobile,
  isAdmin,
  savingIds,
  soakedIds,
  onAction,
  onOpenPlan,
  getActionLabel,
}: OverdueBannerProps) => {
  // Zoskupíme podľa kategórie
  const grouped = useMemo(() => {
    const map = new Map<TaskCategoryKey, BaseTaskItem[]>();
    for (const t of tasks) {
      const arr = map.get(t.category) || [];
      arr.push(t);
      map.set(t.category, arr);
    }
    return map;
  }, [tasks]);

  return (
    <div className="bg-[#fef2f2] rounded-xl border border-[#fecaca] shadow-sm overflow-hidden">
      <div className="px-4 py-3 border-b border-[#fecaca] bg-[#fef2f2] flex items-center gap-3">
        <div className="flex-shrink-0 w-9 h-9 rounded-lg bg-[#fee2e2] flex items-center justify-center">
          <AlertTriangle className="h-4 w-4 text-[#dc2626]" />
        </div>
        <div className="flex-1 min-w-0">
          <h3 className="text-sm font-bold text-[#0f172a]">Meškajúce úlohy</h3>
          <p className="text-[11px] text-[#475569]">
            {tasks.length} {tasks.length === 1 ? 'úloha mešká' : (tasks.length >= 2 && tasks.length <= 4 ? 'úlohy meškajú' : 'úloh mešká')}
          </p>
        </div>
        <span className="inline-flex items-center justify-center min-w-[24px] h-6 px-2 rounded-full bg-[#fee2e2] text-[#dc2626] text-[11px] font-bold">
          {tasks.length}
        </span>
      </div>

      <div className="bg-white">
        {Array.from(grouped.entries()).map(([catKey, catTasks]) => {
          const config = CATEGORY_CONFIG[catKey];
          const CatIcon = config.icon;
          return (
            <div key={catKey} className="border-b border-[#e2e8f0] last:border-0">
              <div className="px-4 py-2 bg-[#fafafa] flex items-center gap-2">
                <CatIcon className="h-3.5 w-3.5" style={{ color: config.iconColor }} />
                <span className="text-xs font-bold text-[#475569] uppercase tracking-wide">
                  {config.title}
                </span>
                <span className="text-[10px] text-[#94a3b8]">({catTasks.length})</span>
              </div>
              <div className="divide-y divide-[#e2e8f0]">
                {catTasks.map(task => (
                  <TaskItem
                    key={task.id}
                    task={task}
                    isAdmin={isAdmin}
                    isSaving={task.planId ? savingIds.has(task.planId) : false}
                    isCompleted={task.category === 'soaking' && !!task.planId && soakedIds.has(task.planId)}
                    isOverdueRow
                    onAction={onAction}
                    onOpenPlan={onOpenPlan}
                    getActionLabel={getActionLabel}
                  />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
};
