import { useIsMobile } from '@/hooks/use-mobile';
import { useNavigate } from 'react-router-dom';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Skeleton } from '@/components/ui/skeleton';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import {
  Sprout,
  Sun,
  Moon,
  Scissors,
  Truck,
  Weight,
  Droplets,
  AlertTriangle,
  CheckCircle2,
  ChevronDown,
  ChevronUp,
  Calendar as CalendarIcon,
  ExternalLink,
  Scale,
  Loader2,
  FlaskConical,
  Layers,
  Package,
} from 'lucide-react';
import { format, addDays, parseISO, subHours, startOfDay, isSameDay, differenceInDays } from 'date-fns';
import { sk } from 'date-fns/locale';
import { cn } from '@/lib/utils';

// ===================== TYPES =====================

interface Crop {
  id: string;
  name: string;
  color: string;
  category?: string;
  days_to_harvest: number;
  days_in_darkness: number;
  days_on_light: number;
  blackout_days?: number | null;
  needs_weight: boolean;
  seed_soaking: boolean;
  soaking_duration_hours?: number | null;
  tray_configs?: Record<string, { seed_density?: number; seed_density_grams?: number; expected_yield?: number; yield_grams?: number }>;
}

interface PlantingPlan {
  id: string;
  crop_id: string | null;
  sow_date: string;
  expected_harvest_date: string | null;
  tray_size: 'XL' | 'L' | 'M' | 'S';
  tray_count: number;
  seed_amount_grams: number;
  total_seed_grams: number;
  status: 'planned' | 'in_progress' | 'completed' | 'cancelled';
  notes?: string | null;
  is_manual?: boolean;
  is_mixed?: boolean;
  is_test?: boolean;
  mix_configuration?: any;
  source_orders?: string[] | null;
  completed_at?: string | null;
  actual_yield_grams?: number | null;
  weight_removed_at?: string | null;
  blackout_started_at?: string | null;
  blackout_ended_at?: string | null;
  moved_to_light_at?: string | null;
  crops?: Crop | null;
}

interface OrderItem {
  crop_id: string | null;
  quantity: number;
  packaging_size: string | null;
  crops?: { id: string; name: string; color: string } | null;
}

interface Order {
  id: string;
  order_number: number;
  customer_name: string | null;
  delivery_date: string;
  delivery_form: string | null;
  status: string;
  skipped: boolean | null;
  order_items: OrderItem[];
}

type TaskCategoryKey = 'soaking' | 'sowing' | 'weight' | 'cover_bo' | 'light' | 'harvest' | 'delivery';

interface BaseTaskItem {
  id: string;
  category: TaskCategoryKey;
  cropId: string | null;
  cropName: string;
  cropColor: string;
  trayInfo: string; // "3×XL"
  seedGrams: number;
  isMixed: boolean;
  isTest: boolean;
  isManual: boolean;
  isOverdue: boolean;
  overdueLabel?: string; // "Včera", "Pred 3 dňami"
  planId?: string;
  orderId?: string;
  orderNumber?: number;
  customerName?: string;
  deliveryForm?: string;
}

interface CategoryConfig {
  key: TaskCategoryKey;
  title: string;
  icon: React.ComponentType<{ className?: string }>;
  bgColor: string;
  iconColor: string;
  emptyText: string;
}

// ===================== CONSTANTS =====================

